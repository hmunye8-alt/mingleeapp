<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Arka plan rengi -->
    <solid android:color="#FFFFFF"/>

    <!-- Kenar çizgisi -->
    <stroke
        android:width="1dp"
        android:color="#CCCCCC"/>

    <!-- Köşeleri yuvarlat -->
    <corners android:radius="12dp"/>

    <!-- İç boşluk -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>